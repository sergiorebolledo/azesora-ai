# Secretos: nunca deben entrar al contexto de build ni quedar horneados en la imagen
.env
.streamlit/secrets.toml

# Entorno local de Windows (no aplica dentro del contenedor Linux)
.venv/

# Control de versiones y config de herramientas de desarrollo
.git/
.gitignore
.dockerignore
.claude/

# Datos derivados/regenerables: se incluye vector_db/ pre-construido a proposito para evitar
# reindexar en maquinas con poca RAM/CPU (ver src/mantencion.py, que respeta el manifiesto si coincide)
logs/

# Basura de Python
__pycache__/
*.pyc
*.pyo
